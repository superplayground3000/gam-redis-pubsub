# Example overlay for running the rrcs-k8s lab against pre-existing external
# NATS JetStream and Redis. Copy to a real values file (NOT committed), fill
# in your URLs, and pre-create the K8s Secrets referenced below.
#
# In external mode the bundled nats-init Job is DISABLED (gated on
# `not .Values.nats.external.enabled`), so the chart never creates or reconciles
# your STREAM — you must pre-create that yourself. The durable PULL consumer the
# sink binds to (bind:true) IS handled: the chart runs a separate external init
# Job (templates/nats-init-external-job.yaml) as a pre-install/pre-upgrade Helm
# HOOK, so helm BLOCKS on it and a failure FAILS the `helm install/upgrade`
# (the sink is never deployed against a broken consumer). It verifies the stream
# exists, then creates the pull consumer if it is absent. If the consumer already
# exists the Job validates it and FAILS CLOSED when it is unusable (PUSH, which
# bind:true cannot attach to), stale (filter_subject no longer matches the
# subjectPrefix), or would weaken at-least-once delivery (ack_policy != explicit,
# or a max_deliver differing from values that could drop messages) — it never
# mutates your consumer, but it also never reports success while the sink would
# be broken; fix or delete it and re-run. It authenticates with adminSecret if set,
# else subscriberSecret (whose JWT must carry the CONSUMER.*CREATE grants —
# gen-nats-auth.sh mints them). Auth everywhere is credential-file based (NATS
# `.creds` / Connect `user_credentials_file`); no user/pass or token path.
#
# Prerequisites you must satisfy in your external NATS account:
#   - The stream named by nats.stream.name (default KV_CDC) must exist and bind
#     subjects "<nats.stream.subjectPrefix>.>" (default "kv.cdc.>"). The external
#     init Job fail-closes (exits non-zero, backoff-retries) until it exists.
#   - The durable PULL consumer named by nats.stream.consumer.durable (default
#     cdc_sink) is auto-created by the external init Job. You only need to
#     pre-create it by hand if NEITHER adminSecret nor a CREATE-capable
#     subscriber is available — then use the bundled helper (credential-file
#     auth; defaults already match nats.stream.*: STREAM=KV_CDC CONSUMER=cdc_sink
#     FILTER='kv.cdc.>'; override via env if you changed them):
#       NATS_CLI="nats --server nats://nats.prod.example.com:4222 \
#         --creds /path/admin.creds" RUN=1 scripts/create-consumer.sh
#   - The publisher user JWT must allow: pub <subjectPrefix>.> and
#     pub $JS.API.STREAM.INFO.<stream>; sub _INBOX.>
#   - The subscriber user JWT. In pull/bind mode the sink only needs to BIND +
#     fetch + ack, i.e. pub $JS.API.CONSUMER.INFO.<stream>.<durable>,
#     pub $JS.API.CONSUMER.MSG.NEXT.<stream>.<durable>,
#     pub $JS.ACK.<stream>.<durable>.>, pub $JS.API.STREAM.INFO.<stream>;
#     sub _INBOX.>. The bundled generator scripts/gen-nats-auth.sh ALSO grants
#     the consumer-CREATE subjects ($JS.API.CONSUMER.DURABLE.CREATE.<stream>.
#     <durable>, $JS.API.CONSUMER.CREATE.<stream>.<durable>[.>]) for back-compat
#     with non-bind (push) configs — harmless to keep. If you mint your own
#     creds, mirror that script (the authoritative grant set) rather than this
#     minimal list, or you may diverge from what the rest of the lab assumes.
#   - The cred that CREATES the durable — the external init Job's adminSecret
#     (else subscriberSecret), or whatever you run create-consumer.sh with — must
#     allow pub $JS.API.CONSUMER.DURABLE.CREATE.<stream>.<durable> and
#     pub $JS.API.STREAM.INFO.<stream>. The admin cred below (pub $JS.API.>)
#     covers this; the gen-nats-auth.sh subscriber's CREATE grants do too.
#   - (Optional) admin user JWT with pub $JS.API.> for the harness purge.
#
# Pre-create the Secrets (keys: user.creds):
#   kubectl create secret generic prod-publisher-creds  --from-file=user.creds=publisher.creds  -n rrcs-k8s
#   kubectl create secret generic prod-subscriber-creds --from-file=user.creds=subscriber.creds -n rrcs-k8s
#   kubectl create secret generic prod-admin-creds      --from-file=user.creds=admin.creds      -n rrcs-k8s   # optional

nats:
  external:
    enabled: true
    url: "nats://nats.prod.example.com:4222"
    monitorUrl: "http://nats-monitor.prod.example.com:8222"   # required for chaos mode
    auth:
      publisherSecret: prod-publisher-creds
      subscriberSecret: prod-subscriber-creds
      adminSecret: prod-admin-creds                          # optional; "" skips harness purge
  # stream.subjectPrefix must match the prefix bound into your stream and the
  # one your publisher creds are authorized to publish on. Default "kv.cdc"
  # works only if your external NATS uses that exact prefix. In external mode
  # the chart does NOT reconcile your stream — changing subjectPrefix here
  # without first updating your stream's bound subjects (and your publisher
  # creds) will cause every published message to be rejected.
  # stream:
  #   subjectPrefix: "tenantA.events"

redis:
  # NOTE: external Redis TLS (rediss://) is NOT supported in v1. Connect can
  # speak TLS, but the writer + collector + init-container redis clients
  # consume host:port only and would silently downgrade to plain TCP. Use
  # redis:// for v1 (the chart will fail-render with a clear error if you set
  # rediss://). External Redis password/ACL auth is also deferred (spec §2
  # non-goal); both will be wired together in a follow-up.
  central:
    external:
      enabled: true
      url: "redis://redis-central.prod.example.com:6379"
  region:
    external:
      enabled: true
      url: "redis://redis-region.prod.example.com:6379"

# Writer/collector still locally built; load into your cluster's registry or kind:
#   scripts/build-images.sh --registry=corp.example.com/team --push
images:
  registry: corp.example.com/team/   # if you pushed; or "" if loaded into kind

# Optional: pick a different prefix for the bundled chart-rendered resources.
# Has no effect on user-supplied external Secret/URL names — those pass
# through verbatim. Default "lab-".
# resourcePrefix: "tenant-a-"
