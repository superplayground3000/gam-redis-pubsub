<mxfile>
  <diagram id="method-1" name="Lab method">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="50" value="verify-failover.sh — one leg (run twice: baseline then fixed)" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="700" height="30" as="geometry" />
        </mxCell>

        <mxCell id="2" value="start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="75" width="200" height="45" as="geometry" />
        </mxCell>

        <mxCell id="3" value="helm upgrade  (--set consumerClientId, maxInFlight=1, readLimit=2000)&#10;+ rollout restart connect-source" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="150" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="4" value="FLUSHDB region;  burst N=5000 distinct-key create events&#10;(fresh per-run key prefix + event_id namespace)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="240" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="5" value="ARM:  poll the CURRENT leader's PEL until depth ≥ threshold&#10;(require holder stable across 2 polls);&#10;re-confirm holder == armed immediately before kill — else INCONCLUSIVE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="330" width="320" height="85" as="geometry" />
        </mxCell>

        <mxCell id="6" value="SIGKILL the leader   (kubectl delete pod --grace-period=0 --force)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="445" width="300" height="50" as="geometry" />
        </mxCell>

        <mxCell id="7" value="wait failover (new Lease holder)&#10;+ adaptive sink-settle: poll region key count until it STOPS growing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="525" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="8" value="MEASURE (pure redis-cli):&#10;residual = pending under CID after settle    |    loss = N − region_present" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="615" width="300" height="60" as="geometry" />
        </mxCell>

        <mxCell id="9" value="assert&#10;(per leg)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="505" y="705" width="150" height="90" as="geometry" />
        </mxCell>

        <mxCell id="10" value="BASELINE&#10;residual &gt; 0  AND  loss &gt; 0&#10;⇒ LOSS reproduced  (757 / 757)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="90" y="715" width="290" height="70" as="geometry" />
        </mxCell>

        <mxCell id="11" value="FIXED&#10;residual == 0  AND  loss == 0&#10;⇒ NO LOSS  (0 / 0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="790" y="715" width="290" height="70" as="geometry" />
        </mxCell>

        <!-- ===== EDGES (vertical spine) ===== -->
        <mxCell id="20" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="2" target="3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="21" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="3" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="22" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="23" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="5" target="6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="24" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="6" target="7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="25" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="7" target="8" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="26" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="8" target="9" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- assert → baseline outcome (left) -->
        <mxCell id="27" value="baseline" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;" edge="1" source="9" target="10" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- assert → fixed outcome (right) -->
        <mxCell id="28" value="fixed" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;" edge="1" source="9" target="11" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
