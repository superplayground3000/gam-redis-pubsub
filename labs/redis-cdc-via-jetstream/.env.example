# Copy to .env to override defaults. Compose reads .env automatically.

# Host port exposures (high range to avoid collisions with user services).
REDIS_SOURCE_HOST_PORT=15301
REDIS_SINK_HOST_PORT=15302
NATS_HOST_PORT=15422
NATS_MONITORING_HOST_PORT=15822

# Source-side Redis Stream name.
STREAM_NAME=events

# Bridge consumer group on Redis-source.
SOURCE_GROUP=bridge

# NATS JetStream stream and consumer names.
NATS_STREAM=EVENTS
NATS_SUBJECT_PREFIX=events
NATS_DURABLE=bridge-consumer

# Total events the server will produce, and inter-event spacing.
MAX_MESSAGES=100
INTERVAL_MS=100
