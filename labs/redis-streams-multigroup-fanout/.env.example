# Copy to .env to override defaults. Compose reads .env automatically.

# Host port exposed for the Redis service (use a high port to avoid collisions).
REDIS_HOST_PORT=15379

# Stream name used by producer and consumers.
STREAM_NAME=events

# How many entries the producer will write before exiting.
MAX_MESSAGES=10

# Interval between produced messages (milliseconds).
INTERVAL_MS=1000
