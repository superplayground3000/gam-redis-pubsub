# Copy to .env to override defaults. All values shown are the defaults.

# Host ports (all in the 15xxx range to avoid collision with other labs).
CENTRAL_REDIS_HOST_PORT=15401
REGION_REDIS_HOST_PORT=15402
NATS_HOST_PORT=15422
NATS_MONITORING_HOST_PORT=15822
VECTOR_API_HOST_PORT=15686
DASHBOARD_HOST_PORT=15500

# Pipeline names — must match across services.
STREAM_NAME=cdc:events
CONSUMER_GROUP=cdc-bridge
CONSUMER_NAME=relay-1
NATS_STREAM=REGION_CDC
NATS_DURABLE=region-applier

# Producer cadence. Set MAX_TICKS to a positive integer to make it finite.
EMIT_INTERVAL_MS=1000
MAX_TICKS=0

# Vector log level.
VECTOR_LOG=info
