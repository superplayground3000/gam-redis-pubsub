<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>LWW Sweep Report &#8212; {{.Lab}}</title>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: ui-monospace, "SFMono-Regular", Consolas, "Liberation Mono", monospace; background: #0f1117; color: #e2e8f0; padding: 2rem; }
  h1 { font-size: 1.4rem; font-weight: 700; color: #f8fafc; margin-bottom: 1.5rem; letter-spacing: 0.05em; }
  .banner { display: inline-block; padding: 0.5rem 1.2rem; border-radius: 6px; font-size: 1rem; font-weight: 600; margin-bottom: 2rem; }
  .banner.green { background: #14532d; color: #86efac; border: 1px solid #16a34a; }
  .banner.gray  { background: #1e2332; color: #94a3b8; border: 1px solid #334155; }
  h2 { font-size: 1rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 0.75rem; }
  section { margin-bottom: 2.5rem; }
  table { border-collapse: collapse; width: 100%; font-size: 0.85rem; }
  th { background: #1e2332; color: #94a3b8; text-align: left; padding: 0.5rem 0.75rem; border-bottom: 1px solid #334155; font-weight: 600; letter-spacing: 0.04em; }
  td { padding: 0.45rem 0.75rem; border-bottom: 1px solid #1e2332; vertical-align: middle; }
  tr:hover td { background: #1a1f2e; }
  .badge { display: inline-block; padding: 0.15rem 0.55rem; border-radius: 4px; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.06em; }
  .badge.pass { background: #14532d; color: #86efac; }
  .badge.fail { background: #4c0519; color: #fca5a5; }
  .bar-wrap { width: 120px; background: #1e2332; border-radius: 3px; overflow: hidden; height: 10px; display: inline-block; vertical-align: middle; }
  .bar-fill { height: 10px; border-radius: 3px; }
  .bar-fill.pass { background: #16a34a; }
  .bar-fill.bar-fail { background: #dc2626; }
  .num { color: #cbd5e1; }
  .mismatch { color: #f87171; font-weight: 700; }
  .zero { color: #4b5563; }
</style>
</head>
<body>
<h1>LWW Sweep Report &#8212; {{safe .Lab}}</h1>

{{if gt .MaxPassingTier 0}}
<div class="banner green">Max passing tier: {{.MaxPassingTier}} msg/s</div>
{{else}}
<div class="banner gray">Max passing tier: 0 msg/s — no tier passed</div>
{{end}}

<section>
  <h2>Correctness Proofs</h2>
  {{if .Proofs}}
  <table>
    <thead>
      <tr>
        <th>Proof</th>
        <th>Result</th>
      </tr>
    </thead>
    <tbody>
      {{range .Proofs}}
      <tr>
        <td>{{safe .Name}}</td>
        <td>{{if .Pass}}<span class="badge pass">PASS</span>{{else}}<span class="badge fail">FAIL</span>{{end}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  {{else}}
  <p style="color:#4b5563;font-size:0.85rem;">No proofs recorded.</p>
  {{end}}
</section>

<section>
  <h2>Throughput Tiers</h2>
  {{if .Tiers}}
  <table>
    <thead>
      <tr>
        <th>Rate (msg/s)</th>
        <th>Applied</th>
        <th>Stale</th>
        <th>Duplicate</th>
        <th>Mismatches</th>
        <th>Tombstones</th>
        <th>Applied bar</th>
        <th>Result</th>
      </tr>
    </thead>
    <tbody>
      {{range .Tiers}}
      <tr>
        <td class="num">{{.Rate}}</td>
        <td class="num">{{.Applied}}</td>
        <td class="num">{{.Stale}}</td>
        <td class="num">{{.Duplicate}}</td>
        <td>{{if gt .Mismatches 0}}<span class="mismatch">{{.Mismatches}}</span>{{else}}<span class="zero">0</span>{{end}}</td>
        <td class="num">{{.Tombstones}}</td>
        <td>
          {{$w := barWidth .Applied}}
          <div class="bar-wrap"><div class="bar-fill{{if .Pass}} pass{{else}} bar-fail{{end}}" style="width:{{$w}}px;"></div></div>
        </td>
        <td>{{if .Pass}}<span class="badge pass">PASS</span>{{else}}<span class="badge fail">FAIL</span>{{end}}</td>
      </tr>
      {{end}}
    </tbody>
  </table>
  {{else}}
  <p style="color:#4b5563;font-size:0.85rem;">No tier data recorded.</p>
  {{end}}
</section>

</body>
</html>
