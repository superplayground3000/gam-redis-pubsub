# Host port mappings (>=15000 to avoid collisions)
CONNECT_PORT=14195
REDIS_PORT=16379
NATS_MON_PORT=18222

# Workload
MSG_COUNT=120          # distinct keys kv:1..kv:N (one message each)
SLEEP_MS=80            # per-msg pipeline sleep = in-flight window
ACK_WAIT=3s            # consumer ack_wait; un-acked redeliver after this
ARM_INFLIGHT=12        # fire close only when num_ack_pending >= this (must be < smallest real batch, e.g. 16)
FAULT_EVERY=10         # experiment 0: mark every Nth key fault_mode=first

# The batch knob under test — swept by smoke-test. Comma-separated.
# fb=1 is drain-clean on close; larger fb replays more on close (never loses).
FETCH_BATCH_SIZES=1,16,256
