# Active QoS profile. One of: alo, amo, eoe.
#   alo = at-least-once          (consumer group + JetStream dedup on Nats-Msg-Id)
#   amo = at-most-once           (drop-on-fail; demonstrates loss after chaos)
#   eoe = exactly-once-effective (alo + event_id dedup gate before sink write)
# Switching profiles: edit this file, then run:
#   docker compose up -d --force-recreate connect-source connect-sink
PROFILE_QOS=alo

# Writer cadence (ms between KV writes).
WRITE_INTERVAL_MS=1000

# Host port mappings. Bump these if they collide with another lab on the host.
DASHBOARD_PORT=16080
REDIS_CENTRAL_PORT=16379
REDIS_REGION_PORT=16380
NATS_CLIENT_PORT=16222
NATS_MON_PORT=18322
CONNECT_SRC_PORT=16195
CONNECT_SINK_PORT=16196
WRITER_METRICS_PORT=16081

# Smoke-test tuning (host shell, NOT compose)
WAIT_FOR_FILL_S=12
SETTLE_BUDGET_MS=8000
CHAOS_DOWN_S=8
CHAOS_CATCHUP_S=15
