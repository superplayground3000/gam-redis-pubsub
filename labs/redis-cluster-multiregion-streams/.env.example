# Per-region client → shard latency (milliseconds, ONE-WAY).
# Round-trip latency observed by the client is roughly 2x these numbers
# (toxiproxy `latency` toxic is applied to both upstream and downstream streams).
#
# Each region sees ONE shard as local, ONE as mid, ONE as far:
#   region A: local=redis-a  mid=redis-b  far=redis-c
#   region B: local=redis-b  mid=redis-a  far=redis-c
#   region C: local=redis-c  mid=redis-b  far=redis-a
LATENCY_LOCAL_MS=1
LATENCY_MID_MS=100
LATENCY_FAR_MS=500

# Client measurement loop period (one full sweep across all 3 streams per tick).
MEASURE_INTERVAL_MS=1000

# Smoke-test thresholds (in ms, on OBSERVED round-trip latency).
# Local: median XADD to local shard must be below this.
# Far:   median XADD to far shard must be above this.
LOCAL_THRESHOLD_MS=80
FAR_THRESHOLD_MS=300

# Minimum samples per (region, target_shard) before the smoke test reads its data.
MIN_SAMPLES=10
