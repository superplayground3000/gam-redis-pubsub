<mxfile>
  <diagram id="latency-ts-flow" name="Latency Timestamp Flow">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1"
                  connect="1" arrows="1" fold="1" page="1" pageScale="1"
                  pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ── Title ── -->
        <mxCell id="40" value="Redis CDC — latency timestamp 由哪些 component 蓋章 &amp; 整條訊息傳遞路徑"
          style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=15;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- ════════ ROW A (y=80): writer → central redis → source → NATS ════════ -->
        <mxCell id="2" value="Writer&#10;(internal/writer)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="170" height="70" as="geometry" />
        </mxCell>

        <mxCell id="3" value="Central Redis&#10;app.events stream"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="330" y="70" width="170" height="90" as="geometry" />
        </mxCell>

        <mxCell id="4" value="Source connector&#10;(cdc-forward.yaml)&#10;Redpanda Connect"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="610" y="80" width="170" height="70" as="geometry" />
        </mxCell>

        <mxCell id="5" value="NATS JetStream&#10;subject &lt;prefix&gt;.&lt;op&gt;"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="880" y="70" width="180" height="90" as="geometry" />
        </mxCell>

        <!-- ════════ ROW B (y=320): sink ← (consume) ; sink → region redis ════════ -->
        <mxCell id="6" value="Sink connector&#10;(cdc-reverse.yaml)&#10;Redpanda Connect"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="880" y="320" width="180" height="85" as="geometry" />
        </mxCell>

        <mxCell id="7" value="Region Redis&#10;KV + cdc:latency stream"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="560" y="315" width="190" height="95" as="geometry" />
        </mxCell>

        <!-- ════════ ROW C (y=560): region redis → latency calculator → report ════════ -->
        <mxCell id="8" value="Latency calculator&#10;(internal/latency)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="560" y="560" width="190" height="80" as="geometry" />
        </mxCell>

        <mxCell id="9" value="latency-report.json&#10;count / p50 / p95 / p99"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="250" y="565" width="180" height="70" as="geometry" />
        </mxCell>

        <!-- ════════ Timestamp callout notes (yellow = the latency story) ════════ -->
        <mxCell id="10" value="&lt;b&gt;writer_ts 在這裡蓋章&lt;/b&gt;&#10;payload.go: snapshot()&#10;body.ts = time.Now().UnixMilli()&#10;(事件建立時)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="220" height="90" as="geometry" />
        </mxCell>

        <mxCell id="11" value="&lt;b&gt;sink_ts 在這裡蓋章&lt;/b&gt;&#10;cdc-reverse.yaml&#10;now().ts_unix_milli()&#10;(apply 前的當下)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="870" y="455" width="210" height="90" as="geometry" />
        </mxCell>

        <mxCell id="12" value="&lt;b&gt;LatencyMs 在這裡計算&lt;/b&gt;&#10;stream.go: ParseSample()&#10;LatencyMs = sink_ts − writer_ts&#10;(只讀取,不蓋章)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;"
          vertex="1" parent="1">
          <mxGeometry x="800" y="555" width="250" height="90" as="geometry" />
        </mxCell>

        <!-- ══════════════════════════════════════════
             EDGES — main path ①–⑧, all connection points explicit
        ══════════════════════════════════════════ -->

        <!-- ① Writer → Central Redis -->
        <mxCell id="20" value="① SET/DEL/RENAME KV + XADD app.events&#10;(body 內含 ts = writer_ts)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="2" target="3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ② Central Redis → Source connector -->
        <mxCell id="21" value="② redis_streams 讀取&#10;(group cdc_propagator)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="3" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ③ Source connector → NATS -->
        <mxCell id="22" value="③ publish JSON envelope&#10;(op/keys/body/ts)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ④ NATS → Sink connector (vertical, A→B) -->
        <mxCell id="23" value="④ consume (JetStream)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="5" target="6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ⑤ Sink → Region Redis : latency telemetry XADD (highlighted) -->
        <mxCell id="24" value="⑤ XADD cdc:latency&#10;{writer_ts, sink_ts}  (apply 前, best-effort)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=0.35;exitDx=0;exitDy=0;entryX=1;entryY=0.35;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;strokeColor=#d6b656;strokeWidth=2;fontColor=#7f6000;fontSize=10;"
          edge="1" source="6" target="7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ⑥ Sink → Region Redis : authoritative apply -->
        <mxCell id="25" value="⑥ SET/DEL/RENAME&#10;(authoritative apply)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=0.7;exitDx=0;exitDy=0;entryX=1;entryY=0.7;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="6" target="7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ⑦ Region Redis → Latency calculator (vertical, B→C) -->
        <mxCell id="26" value="⑦ XRANGE cdc:latency&#10;(rolling 60s window)"
          style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="7" target="8" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ⑧ Latency calculator → Report -->
        <mxCell id="27" value="⑧ write report"
          style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="8" target="9" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ── Dashed annotation links to timestamp notes ── -->
        <mxCell id="28"
          style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;endArrow=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;strokeColor=#d6b656;"
          edge="1" source="2" target="10" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="29"
          style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;endArrow=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;strokeColor=#d6b656;"
          edge="1" source="6" target="11" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="30"
          style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;endArrow=none;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;strokeColor=#d6b656;"
          edge="1" source="8" target="12" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
