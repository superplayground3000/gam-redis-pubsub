<mxfile>
  <diagram id="mech-1" name="Loss vs Fix">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="99" value="What happens to the un-acked PEL on an ungraceful (SIGKILL) failover" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="900" height="30" as="geometry" />
        </mxCell>

        <!-- ===== BASELINE swimlane (LOSS) ===== -->
        <mxCell id="2" value="BASELINE — client_id = __POD__ (pod-scoped)  ⇒  MESSAGE LOSS" style="swimlane;startSize=34;fillColor=#fdeceb;strokeColor=#b85450;fontColor=#b85450;fontStyle=1;fontSize=13;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1100" height="290" as="geometry" />
        </mxCell>
        <mxCell id="3" value="Leader pod-A&#10;consumes as&#10;pod-A" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="2">
          <mxGeometry x="25" y="120" width="165" height="90" as="geometry" />
        </mxCell>
        <mxCell id="4" value="PEL[pod-A]&#10;read-but-unpublished&#10;entries" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="2">
          <mxGeometry x="225" y="110" width="175" height="110" as="geometry" />
        </mxCell>
        <mxCell id="5" value="SIGKILL pod-A&#10;(--grace-period=0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" vertex="1" parent="2">
          <mxGeometry x="435" y="120" width="150" height="90" as="geometry" />
        </mxCell>
        <mxCell id="6" value="New leader pod-B&#10;consumes as pod-B  (NEW name)&#10;reads '&gt;' only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="2">
          <mxGeometry x="620" y="115" width="215" height="100" as="geometry" />
        </mxCell>
        <mxCell id="7" value="PEL[pod-A] ORPHANED&#10;(never XCLAIM'd by pod-B)&#10;→ 757 LOST" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="2">
          <mxGeometry x="880" y="115" width="190" height="100" as="geometry" />
        </mxCell>

        <!-- ===== FIXED swimlane (NO LOSS) ===== -->
        <mxCell id="20" value="FIXED — client_id = cdc_propagator_active (stable)  ⇒  NO LOSS" style="swimlane;startSize=34;fillColor=#eaf5ea;strokeColor=#82b366;fontColor=#5c8a3c;fontStyle=1;fontSize=13;html=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="1100" height="300" as="geometry" />
        </mxCell>
        <mxCell id="21" value="Leader pod-A&#10;consumes as&#10;cdc_propagator_active" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="25" y="125" width="165" height="95" as="geometry" />
        </mxCell>
        <mxCell id="22" value="PEL[cdc_propagator_active]&#10;read-but-unpublished&#10;entries" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="225" y="115" width="175" height="115" as="geometry" />
        </mxCell>
        <mxCell id="23" value="SIGKILL pod-A&#10;(--grace-period=0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="435" y="125" width="150" height="95" as="geometry" />
        </mxCell>
        <mxCell id="24" value="New leader pod-B&#10;consumes as cdc_propagator_active (SAME)&#10;reads '0' → drains PEL, republishes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="20">
          <mxGeometry x="620" y="120" width="215" height="105" as="geometry" />
        </mxCell>
        <mxCell id="25" value="PEL REPLAYED&#10;(dupes absorbed by Nats-Msg-Id)&#10;→ 0 LOST" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;" vertex="1" parent="20">
          <mxGeometry x="880" y="120" width="190" height="105" as="geometry" />
        </mxCell>

        <!-- ===== EDGES (baseline) ===== -->
        <mxCell id="30" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="3" target="4" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="31" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="32" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="5" target="6" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="33" value="orphaned" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#b85450;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontColor=#b85450;fontSize=10;" edge="1" source="6" target="7" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== EDGES (fixed) ===== -->
        <mxCell id="34" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="21" target="22" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="35" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="22" target="23" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="36" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;" edge="1" source="23" target="24" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="37" value="replays '0'" style="edgeStyle=orthogonalEdgeStyle;html=1;strokeColor=#82b366;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;orthogonalLoop=1;jettySize=auto;rounded=1;fontColor=#5c8a3c;fontSize=10;" edge="1" source="24" target="25" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
