<mxfile>
  <diagram id="lab" name="Kind Lab — Components &amp; Data Flow">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1"
                  page="1" pageScale="1" pageWidth="1169" pageHeight="827"
                  math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═════════ Host harness (above cluster) ═════════ -->
        <mxCell id="2"
          value="Host harness:&#10;stress-run.sh &#10142; helm upgrade --install + render collector Job + kubectl apply"
          style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=#ffffff;strokeColor=#999999;fontColor=#333333;fontSize=11;"
          vertex="1" parent="1">
          <mxGeometry x="350" y="40" width="470" height="60" as="geometry" />
        </mxCell>

        <!-- ═════════ Cluster backdrop ═════════ -->
        <mxCell id="3" value="kind cluster: kind-rrcs &#8226; namespace rrcs-k8s &#8226; profile alo"
          style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="160" width="1110" height="480" as="geometry" />
        </mxCell>

        <!-- ═════════ Data-flow row (y=240, h=70) ═════════ -->
        <mxCell id="4" value="lab-writer&#10;(Deployment)&#10;:8081"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;"
