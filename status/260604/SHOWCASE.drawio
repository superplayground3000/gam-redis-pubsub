          vertex="1" parent="1">
          <mxGeometry x="600" y="240" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="8" value="lab-connect-sink&#10;(Redpanda Connect)&#10;4.92.0-claudefix"
