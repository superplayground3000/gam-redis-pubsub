          <mxGeometry x="240" y="240" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="6" value="lab-connect-source&#10;(Redpanda Connect)&#10;4.92.0-claudefix"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="420" y="240" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="7" value="lab-nats&#10;JetStream APP_EVENTS&#10;:4222 / :8222"
