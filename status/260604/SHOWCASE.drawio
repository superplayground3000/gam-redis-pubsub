        <mxCell id="5"
          value="Rebuild &amp; tag&#10;hpdevelop/connect:&#10;4.92.0-claudefix"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="6" value="trivy image scan&#10;(re-verify)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="920" y="80" width="160" height="80" as="geometry" />
        </mxCell>

        <!-- ═════════ Scan-result callouts (y=200) ═════════ -->
        <mxCell id="7" value="BEFORE: 4 CRITICAL &#8226; 26 HIGH"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="240" y="200" width="200" height="50" as="geometry" />
        </mxCell>

        <mxCell id="8" value="AFTER: 0 CRITICAL &#8226; 3 HIGH"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=12;"
          vertex="1" parent="1">
          <mxGeometry x="900" y="200" width="200" height="50" as="geometry" />
        </mxCell>

        <!-- ═════════ Critical CVEs closed (header + 4 boxes, y=320) ═════════ -->
        <mxCell id="9" value="4 CRITICAL CVEs closed"
          style="text;html=1;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;fontColor=#333333;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="400" height="30" as="geometry" />
        </mxCell>

        <mxCell id="10"
          value="&lt;b&gt;CVE-2026-33816&lt;/b&gt;&#10;github.com/jackc/pgx/v5&#10;v5.6.0 &#8594; v5.9.0&#10;&lt;i&gt;Memory-safety vulnerability&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;spacingRight=10;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="260" height="100" as="geometry" />
        </mxCell>

        <mxCell id="11"
          value="&lt;b&gt;CVE-2025-63389&lt;/b&gt;&#10;github.com/ollama/ollama&#10;v0.5.4 (runtime removed upstream)&#10;&lt;i&gt;Missing auth on model mgmt&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;spacingRight=10;"
          vertex="1" parent="1">
          <mxGeometry x="320" y="330" width="260" height="100" as="geometry" />
        </mxCell>

        <mxCell id="12"
          value="&lt;b&gt;CVE-2026-33186&lt;/b&gt;&#10;google.golang.org/grpc&#10;v1.68.0 &#8594; v1.79.3&#10;&lt;i&gt;HTTP/2 authz bypass&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;spacingRight=10;"
          vertex="1" parent="1">
          <mxGeometry x="600" y="330" width="260" height="100" as="geometry" />
        </mxCell>

        <mxCell id="13"
          value="&lt;b&gt;CVE-2025-68121&lt;/b&gt;&#10;Go crypto/tls (stdlib)&#10;1.23.5 &#8594; &#8805;1.24.13&#10;&lt;i&gt;Cert validation on TLS resume&lt;/i&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=10;spacingRight=10;"
          vertex="1" parent="1">
          <mxGeometry x="880" y="330" width="260" height="100" as="geometry" />
        </mxCell>

        <!-- ═════════ Remaining HIGH (y=470) ═════════ -->
        <mxCell id="14"
          value="3 HIGH remain (vendored Go libs &#8212; upstream Connect not yet rebased):&#10;&#8226; github.com/apache/thrift v0.22.0 &#8594; 0.23.0 &#8226; github.com/go-git/go-billy/v5 v5.8.0 &#8594; 5.9.0 &#8226; github.com/go-git/go-git/v5 v5.18.0 &#8594; 5.19.0"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=15;spacingRight=15;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="1100" height="70" as="geometry" />
        </mxCell>

        <!-- ═════════ Runtime verification footer ═════════ -->
        <mxCell id="15"
          value="Runtime verification (per image-fixer skill criteria): connect-source + connect-sink Deployments rolled to 4.92.0-claudefix in the kind lab; tier=10/throughput run achieved PASS (9.9/10 rate, p99 129 ms, 0 missing) &#8212; image confirmed runnable end-to-end."
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=15;spacingRight=15;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="570" width="1100" height="60" as="geometry" />
