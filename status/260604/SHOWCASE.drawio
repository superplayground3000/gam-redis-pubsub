        </mxCell>

        <!-- 11 &#10142; NATS: exitX=0.82 (x=670), direct up -->
        <mxCell id="29" value="GET /jsz"
          style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;
                 exitX=0.82;exitY=0;exitDx=0;exitDy=0;
                 entryX=0.5;entryY=1;entryDx=0;entryDy=0;
