        <!-- 11 &#10142; redis-region: exitX=0.95 (x=706), y=460, right to x=1030 -->
        <mxCell id="30" value="XLEN, XRANGE"
          style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;
                 exitX=0.95;exitY=0;exitDx=0;exitDy=0;
                 entryX=0.5;entryY=1;entryDx=0;entryDy=0;
