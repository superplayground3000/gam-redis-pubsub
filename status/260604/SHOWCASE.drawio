  <diagram id="cve" name="CVE Fix — Redpanda Connect">
    <mxGraphModel dx="0" dy="0" grid="1" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1"
                  page="1" pageScale="1" pageWidth="1169" pageHeight="827"
                  math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ═════════ Workflow row (y=80, h=80) ═════════ -->
        <mxCell id="2"
          value="Original image&#10;redpandadata/connect:4.45.1&#10;(saved as hpdevelop/connect:4.45.1-orig)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="3" value="trivy image scan&#10;(CRITICAL + HIGH)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="260" y="80" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="4"
          value="Fix plan:&#10;upgrade base &#8594; connect:edge (4.92.0)&#10;(major Go stdlib + grpc + pgx refresh,&#10;ollama runtime removed upstream)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="460" y="80" width="200" height="80" as="geometry" />
