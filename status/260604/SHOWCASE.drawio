                 entryX=0;entryY=0.5;entryDx=0;entryDy=0;
                 orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="8" target="9" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- nats-init -> NATS (one-shot stream create) -->
        <mxCell id="26" value="creates stream APP_EVENTS"
          style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;
                 exitX=1;exitY=0.5;exitDx=0;exitDy=0;
                 entryX=0;entryY=0.7;entryDx=0;entryDy=0;
                 orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="10" target="7" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="395" />
              <mxPoint x="580" y="290" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Collector probes (4 lines, staggered exits + waypoints) -->
        <!-- 11 &#10142; writer: exitX=0.05 (x=454), go up to y=440, left to x=130, up to writer bottom -->
        <mxCell id="27" value="POST /reset, GET /metrics"
          style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;
                 exitX=0.05;exitY=0;exitDx=0;exitDy=0;
                 entryX=0.5;entryY=1;entryDx=0;entryDy=0;
                 orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=9;
                 strokeColor=#888888;fontColor=#666666;"
          edge="1" source="11" target="4" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="454" y="440" />
              <mxPoint x="130" y="440" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- 11 &#10142; redis-central: exitX=0.25 (x=510), y=460, left to x=310 -->
        <mxCell id="28" value="XLEN"
          style="edgeStyle=orthogonalEdgeStyle;html=1;dashed=1;
                 exitX=0.25;exitY=0;exitDx=0;exitDy=0;
                 entryX=0.5;entryY=1;entryDx=0;entryDy=0;
                 orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=9;
