          vertex="1" parent="1">
          <mxGeometry x="780" y="240" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="9" value="lab-redis-region&#10;(Deployment)&#10;XSTREAM app.events"
          style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;"
          vertex="1" parent="1">
          <mxGeometry x="960" y="240" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- ═════════ One-shot init Job (left of data flow) ═════════ -->
        <mxCell id="10" value="lab-nats-init Job&#10;(Completed: stream created)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="180" height="50" as="geometry" />
        </mxCell>

        <!-- ═════════ Collector Job + verdict (bottom) ═════════ -->
        <mxCell id="11" value="lab-collector Job (per cell: tier &#215; mode &#215; profile)&#10;verdict: PASS &#8212; 9.9/10 rate, p99 129.3 ms, 0 missing"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;"
          vertex="1" parent="1">
          <mxGeometry x="440" y="510" width="280" height="80" as="geometry" />
        </mxCell>

        <!-- ════════════════════════════════════════════
             EDGES
        ════════════════════════════════════════════ -->

        <!-- host harness &#10142; cluster -->
        <mxCell id="20" value="install &amp; apply"
          style="edgeStyle=orthogonalEdgeStyle;html=1;
                 exitX=0.5;exitY=1;exitDx=0;exitDy=0;
                 entryX=0.5;entryY=0;entryDx=0;entryDy=0;
                 orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="2" target="3" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Data flow chain -->
        <mxCell id="21" value="XADD"
          style="edgeStyle=orthogonalEdgeStyle;html=1;
                 exitX=1;exitY=0.5;exitDx=0;exitDy=0;
                 entryX=0;entryY=0.5;entryDx=0;entryDy=0;
                 orthogonalLoop=1;jettySize=auto;rounded=1;fontSize=10;"
          edge="1" source="4" target="5" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="22" value="XREAD"
          style="edgeStyle=orthogonalEdgeStyle;html=1;
                 exitX=1;exitY=0.5;exitDx=0;exitDy=0;
                 entryX=0;entryY=0.5;entryDx=0;entryDy=0;
